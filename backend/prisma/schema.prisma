generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RH
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntityType {
  CERTIFICATE
  DECLARATION
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  role         Role
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  certificates Certificate[]
  declarations Declaration[]
  auditLogs    AuditLog[]    @relation("UserAuditLogs")
}

model Certificate {
  id               Int          @id @default(autoincrement())
  startDate        DateTime
  endDate          DateTime
  registrationDate DateTime
  employeeName     String
  cpf              String
  cid              String?
  totalDays        Int
  createdById      Int
  createdBy        User         @relation(fields: [createdById], references: [id])
  attachments      Attachment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([employeeName])
  @@index([cpf])
  @@index([cid])
  @@index([registrationDate])
  @@index([startDate, endDate])
}

model Attachment {
  id            Int         @id @default(autoincrement())
  filename      String
  certificateId Int
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([certificateId])
}

model Declaration {
  id                  Int                   @id @default(autoincrement())
  declarationDate     DateTime
  registrationDate    DateTime
  employeeName        String
  cpf                 String
  startTime           String
  endTime             String
  totalMinutes        Int
  createdById         Int
  createdBy           User                  @relation(fields: [createdById], references: [id])
  declarationFiles    DeclarationAttachment[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([employeeName])
  @@index([cpf])
  @@index([registrationDate])
  @@index([declarationDate])
}

model DeclarationAttachment {
  id            Int         @id @default(autoincrement())
  filename      String
  declarationId Int
  declaration   Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([declarationId])
}

model AuditLog {
  id            Int             @id @default(autoincrement())
  action        AuditAction
  entityType    AuditEntityType
  entityId      Int
  performedById Int
  performedBy   User            @relation("UserAuditLogs", fields: [performedById], references: [id])
  employeeName  String
  cpf           String
  beforeData    Json?
  afterData     Json?
  changes       Json?
  createdAt     DateTime        @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([performedById])
  @@index([cpf])
}

