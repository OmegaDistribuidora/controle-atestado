{
  "name": "controle-atestado",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "railway:start": "npm run prisma:generate --workspace backend && npm run prisma:push --workspace backend && npm run build --workspace frontend && npm run start --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}

